---
import Layout from "../layouts/Layout.astro";
import DownloadPanel from "../components/DownloadPanel";
---

<Layout title="Download lde" description="Download lde for your platform.">
	<div class="max-w-3xl mx-auto px-4 sm:px-6 py-16 w-full">
		<div class="text-center mb-12">
			<p class="text-blue-400 text-sm font-semibold uppercase tracking-widest mb-3">Install</p>
			<h1 class="text-4xl md:text-5xl font-bold">Download lde</h1>
			<p class="mt-4 text-black/50 dark:text-white/40">
				Pick your platform and install method. Already installed? Run <code class="text-blue-400 bg-blue-500/10 px-1.5 py-0.5 rounded text-sm">lde upgrade</code>.
			</p>
		</div>
		<DownloadPanel client:load />
	</div>
</Layout>
