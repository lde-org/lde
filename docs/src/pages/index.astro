---
import Layout from "../layouts/Layout.astro";
import InstallTabs from "../components/InstallTabs";
import { GITHUB_RELEASES_URL } from "../data/info";
---

<Layout>
    <!-- Full-width wrapper so the background isn't clipped to max-w -->
    <div class="flex-1 relative flex flex-col">
        <!-- Lunar background -->
        <div
            class="absolute inset-0 overflow-hidden pointer-events-none select-none opacity-100"
            aria-hidden="true"
        >
            <svg
                class="w-full h-full"
                viewBox="0 0 1400 650"
                preserveAspectRatio="xMidYMid slice"
                xmlns="http://www.w3.org/2000/svg"
            >
                <defs>
                    <!-- Two offset tiling patterns make the grid feel irregular -->
                    <pattern
                        id="stars-a"
                        width="97"
                        height="83"
                        patternUnits="userSpaceOnUse"
                    >
                        <circle cx="12" cy="18" r="0.7" fill="#64748b"></circle>
                        <circle cx="58" cy="8" r="0.5" fill="#64748b"></circle>
                        <circle cx="81" cy="47" r="0.8" fill="#64748b"
                        ></circle>
                        <circle cx="28" cy="65" r="0.6" fill="#64748b"
                        ></circle>
                        <circle cx="72" cy="71" r="0.5" fill="#64748b"
                        ></circle>
                        <circle cx="43" cy="38" r="0.4" fill="#64748b"
                        ></circle>
                    </pattern>
                    <pattern
                        id="stars-b"
                        width="113"
                        height="97"
                        patternUnits="userSpaceOnUse"
                        x="37"
                        y="25"
                    >
                        <circle cx="22" cy="44" r="0.6" fill="#64748b"
                        ></circle>
                        <circle cx="78" cy="12" r="0.8" fill="#64748b"
                        ></circle>
                        <circle cx="100" cy="73" r="0.5" fill="#64748b"
                        ></circle>
                        <circle cx="47" cy="82" r="0.7" fill="#64748b"
                        ></circle>
                        <circle cx="91" cy="55" r="0.5" fill="#64748b"
                        ></circle>
                        <circle cx="15" cy="30" r="0.4" fill="#64748b"
                        ></circle>
                        <circle cx="55" cy="55" r="0.4" fill="#64748b"
                        ></circle>
                    </pattern>
                </defs>

                <!-- Star field -->
                <rect
                    width="1400"
                    height="650"
                    fill="url(#stars-a)"
                    opacity="1"></rect>
                <rect
                    width="1400"
                    height="650"
                    fill="url(#stars-b)"
                    opacity="0.9"></rect>

                <!-- A few brighter accent stars -->
                <circle cx="148" cy="115" r="1.5" fill="#3b82f6" opacity="0.7"
                ></circle>
                <circle cx="375" cy="72" r="1.2" fill="#3b82f6" opacity="0.6"
                ></circle>
                <circle cx="595" cy="188" r="1.4" fill="#3b82f6" opacity="0.65"
                ></circle>
                <circle cx="218" cy="478" r="1.3" fill="#3b82f6" opacity="0.6"
                ></circle>
                <circle cx="472" cy="528" r="1.1" fill="#3b82f6" opacity="0.55"
                ></circle>
                <circle cx="88" cy="355" r="1.2" fill="#3b82f6" opacity="0.55"
                ></circle>
                <circle cx="1295" cy="195" r="1.4" fill="#3b82f6" opacity="0.6"
                ></circle>
                <circle cx="1248" cy="548" r="1.3" fill="#3b82f6" opacity="0.65"
                ></circle>
                <circle cx="732" cy="58" r="1.2" fill="#3b82f6" opacity="0.5"
                ></circle>
                <circle cx="955" cy="598" r="1.4" fill="#3b82f6" opacity="0.55"
                ></circle>
            </svg>
        </div>

        <!-- Content -->
        <div
            class="flex flex-col flex-1 p-4 md:p-8 max-w-[90em] mx-auto justify-center w-full"
        >
            <div
                class="p-4 md:p-8 flex flex-col lg:flex-row items-center justify-between gap-8 lg:gap-0"
            >
                <div class="flex flex-col">
                    <h1 class="text-4xl md:text-5xl font-semibold max-w-md">
                        Lua Done
                        <span class="easy-underline relative"> Easy </span>
                    </h1>

                    <style>
                        .easy-underline::after {
                            content: "";
                            position: absolute;
                            bottom: -4px;
                            left: 0;
                            height: 4px;
                            width: 0;
                            background-color: #3b82f6;
                            animation: underline-slide-in 0.6s ease-out 0.3s
                                forwards;
                        }

                        @keyframes underline-slide-in {
                            from {
                                width: 0;
                            }
                            to {
                                width: 100%;
                            }
                        }
                    </style>

                    <p class="my-6 md:my-8 text-lg max-w-lg">
                        Lpm is an open-source project providing easy
                        accessibility to a Lua runtime alongside intuitive
                        package management for dependencies.
                    </p>

                    <div class="hidden lg:block">
                        <InstallTabs client:idle />
                    </div>

                    <a
                        href={GITHUB_RELEASES_URL}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="lg:hidden inline-flex items-center justify-center px-6 py-3 bg-blue-500/10 border border-blue-500/30 text-blue-500 font-medium rounded-lg backdrop-blur-md w-fit"
                    >
                        Download
                    </a>
                </div>

                <div class="relative hidden lg:block mt-4">
                    <!-- Orbital rings, always centered on the logo -->
                    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-[calc(50%+24px)] size-[350px] rounded-full border border-slate-500/40 dark:border-slate-400/25 pointer-events-none"></div>
                    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-[calc(50%+24px)] size-[560px] rounded-full border border-slate-500/25 dark:border-slate-400/15 pointer-events-none"></div>
                    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-[calc(50%+24px)] size-[800px] rounded-full border border-slate-500/15 dark:border-slate-400/[0.08] pointer-events-none"></div>
                    <div
                        class="absolute inset-0 -mt-12 bg-blue-500/40 dark:bg-blue-500/20 rounded-full blur-3xl scale-125"
                    >
                    </div>
                    <img
                        src="/lpm-small.svg"
                        alt="lpm logo"
                        class="size-96 -mt-12 relative"
                        fetchpriority="high"
                    />
                </div>
            </div>
        </div>
    </div>
</Layout>
